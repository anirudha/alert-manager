{
  "name": "alert-manager",
  "version": "1.0.0",
  "private": true,
  "description": "Alert Manager plugin for OpenSearch Dashboards with multi-backend alerting support",
  "license": "Apache-2.0",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .js,.ts,.tsx --ignore-pattern standalone/dist --ignore-pattern standalone/node_modules",
    "lint:fix": "eslint . --ext .js,.ts,.tsx --fix --ignore-pattern standalone/dist --ignore-pattern standalone/node_modules",
    "build": "yarn plugin-helpers build",
    "build:standalone": "cd standalone && npm install && npm run build",
    "start:standalone": "cd standalone && npm run start",
    "dev:standalone": "cd standalone && npm run dev",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "e2e": "start-server-and-test 'MOCK_MODE=true node standalone/dist/standalone/server.js' http://localhost:5603 'cypress run'",
    "plugin-helpers": "../../scripts/use_node ../../scripts/plugin_helpers",
    "osd": "../../scripts/use_node ../../scripts/osd",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js}": [
      "prettier --write"
    ]
  },
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/opensearch-project/dashboards-observability.git",
    "directory": "plugins/alert-manager"
  },
  "bugs": {
    "url": "https://github.com/opensearch-project/dashboards-observability/issues"
  },
  "homepage": "https://github.com/opensearch-project/dashboards-observability#alert-manager",
  "dependencies": {
    "echarts": "^6.0.0"
  },
  "devDependencies": {
    "@cypress/webpack-preprocessor": "^7.0.2",
    "@testing-library/dom": "^8.11.3",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^14.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "~20.10.5",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "ajv": "^8.18.0",
    "cypress": "^15.13.1",
    "eslint-plugin-jest": "^26.1.1",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-react-hooks": "^4.0.4",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "start-server-and-test": "^3.0.0",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "typescript": "~6.0.2",
    "webpack": "^5.104.1"
  }
}
